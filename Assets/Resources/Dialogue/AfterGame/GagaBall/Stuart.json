    {
      "speakerName": "Dr Oliver",
      "dialogueLine": "The activity has ended.",
      "textSpeed": 0.1
    },
    {
      "speakerName": "Dr Oliver",
      "dialogueLine": " You did good there with that suggestion. That played a big role in our success there.",
      "textSpeed": 0.1
