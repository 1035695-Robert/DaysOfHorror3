    {
      "speakerName": "Clancy",
      "dialogueLine": "A- A..",
      "textSpeed": 0.1
    },
    {
      "speakerName": "Dr Oliver",
      "dialogueLine": "<b>You were selfish, Clancy.</b>",
      "textSpeed": 0.1
    },
    {
      "speakerName": "Dr Oliver",
      "dialogueLine": "Your self-concern was what killed them.",
      "textSpeed": 0.1
    },
    {
      "speakerName": "Dr Oliver",
      "dialogueLine": "Rather than work together to try and see how you could all get out alive, you chose to selfishly save your own skin.",
      "textSpeed": 0.1
