    {
      "speakerName": "Clancy",
      "dialogueLine": "...",
      "textSpeed": 0.1
    },
    {
      "speakerName": "Dr Oliver",
      "dialogueLine": "Through direct experience, you will see the truth.",
      "textSpeed": 0.1
    },
    {
      "speakerName": "Dr Oliver",
      "dialogueLine": "This activity and its outcome have built towards seeing that truth, Clancy.",
      "textSpeed": 0.1
    },
    {
      "speakerName": "Dr Oliver",
      "dialogueLine": "The most important thing… is every life in the world around us.",
      "textSpeed": 0.1
